{
  "name": "aegis",
  "version": "0.0.1",
  "private": true,
  "description": "A monitoring tool to expose the result of on-chain view calls as prometheus metrics that get ingested into grafana.",
  "license": "UNLICENSED",
  "author": "Mento Labs <eng@mentolabs.xyz>",
  "scripts": {
    "build": "nest build",
    "deploy": "./bin/deploy.sh",
    "dev": "nest start --watch",
    "format": "trunk fmt",
    "grafana": "open $(terraform -chdir=terraform state show module.grafana_dashboard.grafana_dashboard.aegis | grep 'url' | awk -F '\"' '{print $2}')",
    "lint": "trunk check --all",
    "logs": "./bin/logs.sh",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:watch": "jest --watch",
    "tf:deploy": "terraform -chdir=terraform apply",
    "tf:destroy": "terraform -chdir=terraform destroy",
    "tf:init": "terraform -chdir=terraform init",
    "trunk": "trunk"
  },
  "jest": {
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/schedule": "^6.0.1",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "abitype": "^1.1.2",
    "cron": "^4.3.4",
    "js-yaml": "^4.1.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "viem": "^2.39.2",
    "zod": "^4.1.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.12",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@trunkio/launcher": "^1.0.0",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "^22.0.0"
  },
  "volta": {
    "node": "22.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "unrs-resolver"
    ],
    "overrides": {
      "@eslint/eslintrc": ">=3.3.5",
      "@nestjs/core": ">=11.1.18",
      "ajv@^6.0.0": "^6.14.0",
      "ajv@^8.0.0": ">=8.18.0",
      "body-parser": ">=2.2.1",
      "brace-expansion@^1.0.0": "^1.1.13",
      "brace-expansion@^2.0.0": "^2.0.3",
      "cron": "4.3.4",
      "diff@^4.0.0": "^4.0.4",
      "file-type@^21.0.0": "^21.3.2",
      "flatted": ">=3.4.2",
      "handlebars": ">=4.7.9",
      "lodash": ">=4.17.23",
      "minimatch@^3.0.0": "^3.1.4",
      "minimatch@^9.0.0": "^9.0.7",
      "minimatch@^10.0.0": "^10.2.3",
      "multer": ">=2.1.1",
      "path-to-regexp@^8.0.0": "^8.4.0",
      "picomatch@^2.0.0": "^2.3.2",
      "picomatch@^4.0.0": "^4.0.4",
      "qs": ">=6.14.2",
      "tar": ">=7.5.11",
      "webpack": ">=5.104.1",
      "yaml@^2.0.0": "^2.8.3"
    }
  }
}
